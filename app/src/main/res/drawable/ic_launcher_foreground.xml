<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
        Receipt + dog-ear, wrapped in a 15° rotation group around the receipt centre
        (54,54) so it tilts together with the $ below.
    -->
    <group
        android:pivotX="54"
        android:pivotY="54"
        android:rotation="15">

        <!--
            Receipt with cut corner at the top-left. Path runs clockwise:
              starts at (42,30) where the top edge begins after the fold,
              across the top, down the right, zigzag along the bottom,
              up the left to (34,38) where the fold meets,
              then a diagonal back up to the start.
            The cut corner reveals the icon background.
        -->
        <path
            android:pathData="M42,30 L74,30 L74,72 L69,78 L64,72 L59,78 L54,72 L49,78 L44,72 L39,78 L34,72 L34,38 L42,30 Z">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:type="radial"
                    android:centerX="54"
                    android:centerY="54"
                    android:gradientRadius="30"
                    android:startColor="#F8F2E3"
                    android:endColor="#C9C2B0" />
            </aapt:attr>
        </path>

        <!--
            Dog-ear flap: the geometric reflection of the cut corner (34,30) across
            the fold line (42,30)-(34,38). Reflected vertex lands at (42,38), giving
            a right triangle whose hypotenuse is the fold line and whose right angle
            is inside the receipt body. Drawn on top of the receipt to read as the
            back of paper folded forward toward the viewer.
        -->
        <path
            android:fillColor="#B5AC95"
            android:pathData="M42,30 L34,38 L42,38 Z" />
    </group>

    <!--
        Extruded "$" — three copies stacked with progressive down-right offsets and
        progressively brighter gold shades. Outer group adds a 15° Z rotation
        (around the glyph's natural pivot at 12,12) plus a 0.966× scaleX to
        approximate a 15° Y-axis tilt. The rotation matches the receipt's rotation,
        so the letter and the page tilt together.
    -->
    <group
        android:translateX="42"
        android:translateY="39"
        android:pivotX="12"
        android:pivotY="12"
        android:rotation="15"
        android:scaleX="1.16"
        android:scaleY="1.5">

        <!-- Back layer: deepest shade. -->
        <group android:translateX="2" android:translateY="2">
            <path
                android:fillColor="#5D4A0A"
                android:pathData="M11.8,10.9c-2.27,-0.59 -3,-1.2 -3,-2.15c0,-1.09 1.01,-1.85 2.7,-1.85c1.78,0 2.44,0.85 2.5,2.1h2.21c-0.07,-1.72 -1.12,-3.3 -3.21,-3.81V3h-3v2.16c-1.94,0.42 -3.5,1.68 -3.5,3.61c0,2.31 1.91,3.46 4.7,4.13c2.5,0.6 3,1.48 3,2.41c0,0.69 -0.49,1.79 -2.7,1.79c-2.06,0 -2.87,-0.92 -2.98,-2.1h-2.2c0.12,2.19 1.76,3.42 3.68,3.83V21h3v-2.15c1.95,-0.37 3.5,-1.5 3.5,-3.55c0,-2.84 -2.43,-3.81 -4.7,-4.4z" />
        </group>

        <!-- Middle layer: mid gold (DarkGoldenrod). -->
        <group android:translateX="1" android:translateY="1">
            <path
                android:fillColor="#B8860B"
                android:pathData="M11.8,10.9c-2.27,-0.59 -3,-1.2 -3,-2.15c0,-1.09 1.01,-1.85 2.7,-1.85c1.78,0 2.44,0.85 2.5,2.1h2.21c-0.07,-1.72 -1.12,-3.3 -3.21,-3.81V3h-3v2.16c-1.94,0.42 -3.5,1.68 -3.5,3.61c0,2.31 1.91,3.46 4.7,4.13c2.5,0.6 3,1.48 3,2.41c0,0.69 -0.49,1.79 -2.7,1.79c-2.06,0 -2.87,-0.92 -2.98,-2.1h-2.2c0.12,2.19 1.76,3.42 3.68,3.83V21h3v-2.15c1.95,-0.37 3.5,-1.5 3.5,-3.55c0,-2.84 -2.43,-3.81 -4.7,-4.4z" />
        </group>

        <!-- Front layer: lightest gold. -->
        <path
            android:fillColor="#FFD54F"
            android:pathData="M11.8,10.9c-2.27,-0.59 -3,-1.2 -3,-2.15c0,-1.09 1.01,-1.85 2.7,-1.85c1.78,0 2.44,0.85 2.5,2.1h2.21c-0.07,-1.72 -1.12,-3.3 -3.21,-3.81V3h-3v2.16c-1.94,0.42 -3.5,1.68 -3.5,3.61c0,2.31 1.91,3.46 4.7,4.13c2.5,0.6 3,1.48 3,2.41c0,0.69 -0.49,1.79 -2.7,1.79c-2.06,0 -2.87,-0.92 -2.98,-2.1h-2.2c0.12,2.19 1.76,3.42 3.68,3.83V21h3v-2.15c1.95,-0.37 3.5,-1.5 3.5,-3.55c0,-2.84 -2.43,-3.81 -4.7,-4.4z" />
    </group>
</vector>
