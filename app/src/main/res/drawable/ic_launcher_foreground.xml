    <!--
        Receipt outline: a rectangle with a zigzag bottom edge.
        Path runs clockwise from top-left:
          top edge -> right edge down to where the zigzag begins ->
          zigzag right-to-left along the bottom (6 teeth) ->
          left edge back up to top-left.
        Designed to fit within the adaptive-icon safe zone (inner 72×72 of the
        108×108 viewport) so the launcher mask doesn't crop the corners.
    -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M24,18 L84,18 L84,80 L79,88 L74,80 L69,88 L64,80 L59,88 L54,80 L49,88 L44,80 L39,88 L34,80 L29,88 L24,80 L24,18 Z" />

    <!--
